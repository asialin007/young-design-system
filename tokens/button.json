{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "年轻版设计系统 2.0 - Button 组件变量",
  "button": {
    "sizes": {
      "xl": {
        "height": { "value": "48px", "type": "dimension" },
        "minWidth": { "value": "359px", "type": "dimension" },
        "paddingX": { "value": "32px", "type": "spacing" },
        "paddingY": { "value": "14px", "type": "spacing" },
        "fontSize": "{typography.presets.15M.fontSize}",
        "iconSize": { "value": "48px", "type": "dimension", "description": "icon-only 按钮尺寸" },
        "inlineIconSize": { "value": "18px", "type": "dimension", "description": "按钮内嵌图标尺寸（左侧图标）" }
      },
      "large": {
        "height": { "value": "38px", "type": "dimension" },
        "minWidth": { "value": "72px", "type": "dimension" },
        "paddingX": { "value": "16px", "type": "spacing" },
        "paddingY": { "value": "10px", "type": "spacing" },
        "fontSize": "{typography.presets.14M.fontSize}",
        "iconSize": { "value": "40px", "type": "dimension", "description": "icon-only 按钮尺寸" },
        "inlineIconSize": { "value": "16px", "type": "dimension", "description": "按钮内嵌图标尺寸（左侧图标）" }
      },
      "medium": {
        "height": { "value": "32px", "type": "dimension" },
        "minWidth": { "value": "60px", "type": "dimension" },
        "paddingX": { "value": "14px", "type": "spacing" },
        "paddingY": { "value": "8px", "type": "spacing" },
        "fontSize": "{typography.presets.14M.fontSize}",
        "iconSize": { "value": "32px", "type": "dimension", "description": "icon-only 按钮尺寸" },
        "inlineIconSize": { "value": "16px", "type": "dimension", "description": "按钮内嵌图标尺寸（左侧图标）" }
      },
      "mediumSmall": {
        "height": { "value": "28px", "type": "dimension" },
        "minWidth": { "value": "60px", "type": "dimension" },
        "paddingX": { "value": "12px", "type": "spacing" },
        "paddingY": { "value": "6px", "type": "spacing" },
        "fontSize": "{typography.presets.13R.fontSize}",
        "inlineIconSize": { "value": "14px", "type": "dimension", "description": "按钮内嵌图标尺寸（左侧图标）" }
      },
      "small": {
        "height": { "value": "24px", "type": "dimension" },
        "minWidth": { "value": "48px", "type": "dimension" },
        "paddingX": { "value": "10px", "type": "spacing" },
        "paddingY": { "value": "4px", "type": "spacing" },
        "fontSize": "{typography.presets.12R.fontSize}",
        "iconSize": { "value": "24px", "type": "dimension", "description": "icon-only 按钮尺寸" },
        "inlineIconSize": { "value": "14px", "type": "dimension", "description": "按钮内嵌图标尺寸（左侧图标）" }
      },
      "mini": {
        "height": { "value": "20px", "type": "dimension" },
        "minWidth": { "value": "38px", "type": "dimension" },
        "paddingX": { "value": "8px", "type": "spacing" },
        "paddingY": { "value": "2px", "type": "spacing" },
        "fontSize": "{typography.presets.11R.fontSize}",
        "iconSize": { "value": "20px", "type": "dimension", "description": "icon-only 按钮尺寸" },
        "inlineIconSize": { "value": "12px", "type": "dimension", "description": "按钮内嵌图标尺寸（左侧图标）" }
      }
    },
    "variants": {
      "solidDark": {
        "brand": {
          "default": {
            "background": "{colors.brand.primary}",
            "color": "{colors.neutral.white}",
            "border": "none"
          },
          "disabled": {
            "background": "{colors.opacity.black-4}",
            "color": "{colors.opacity.black-24}",
            "border": "none"
          }
        },
        "black": {
          "default": {
            "background": "{colors.neutral.black}",
            "color": "{colors.neutral.white}",
            "border": "none"
          },
          "disabled": {
            "background": "{colors.opacity.black-4}",
            "color": "{colors.opacity.black-24}",
            "border": "none"
          }
        }
      },
      "solidLight": {
        "brand": {
          "default": {
            "background": "{colors.brand.secondary}",
            "color": "{colors.brand.active}",
            "border": "none"
          },
          "disabled": {
            "background": "{colors.opacity.black-4}",
            "color": "{colors.opacity.black-24}",
            "border": "none"
          }
        },
        "black": {
          "default": {
            "background": "{colors.opacity.black-4}",
            "color": "{colors.neutral.black}",
            "border": "none"
          },
          "disabled": {
            "background": "{colors.opacity.black-4}",
            "color": "{colors.opacity.black-24}",
            "border": "none"
          }
        },
        "white": {
          "default": {
            "background": "{colors.neutral.white}",
            "color": "{colors.neutral.black}",
            "border": "none"
          },
          "disabled": {
            "background": "{colors.opacity.black-4}",
            "color": "{colors.opacity.black-24}",
            "border": "none"
          }
        }
      },
      "outlined": {
        "brand": {
          "default": {
            "background": "transparent",
            "color": "{colors.brand.active}",
            "border": "1px solid {colors.brand.hover}"
          },
          "disabled": {
            "background": "transparent",
            "color": "{colors.opacity.black-24}",
            "border": "1px solid {colors.opacity.black-24}"
          }
        },
        "white": {
          "default": {
            "background": "transparent",
            "color": "{colors.neutral.white}",
            "border": "1px solid {colors.opacity.white-95}"
          },
          "disabled": {
            "background": "transparent",
            "color": "{colors.opacity.white-50}",
            "border": "1px solid {colors.opacity.white-24}"
          }
        },
        "black": {
          "default": {
            "background": "transparent",
            "color": "{colors.neutral.black}",
            "border": "1px solid {colors.opacity.black-95}"
          },
          "disabled": {
            "background": "transparent",
            "color": "{colors.opacity.black-24}",
            "border": "1px solid {colors.opacity.black-24}"
          }
        }
      }
    }
  }
}
